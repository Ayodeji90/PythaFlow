m", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": "Graycliff/docs/Voice_Agent_Architecture.md"}, {"id": "build_vs_buy_decision", "label": "Build-vs-buy decision record", "nodes": ["graycliff_docs_voice_agent_architecture_cascaded_pipeline", "graycliff_docs_voice_agent_architecture_managed_platform", "graycliff_docs_voice_agent_architecture_realtime_s2s"], "relation": "participate_in", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": "Graycliff/docs/Voice_Agent_Architecture.md"}]}