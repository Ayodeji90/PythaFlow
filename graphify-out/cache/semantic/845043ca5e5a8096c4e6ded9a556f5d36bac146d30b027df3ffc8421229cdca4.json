{"nodes": [{"id": "graycliff_docs_voice_agent_architecture_voice_concierge", "label": "Voice Concierge (production)", "file_type": "concept", "source_file": "Graycliff/docs/Voice_Agent_Architecture.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "A streaming voice pipeline the guest talks WITH, not a form they talk AT. Replaces the demo /voice page; embedded on graycliff.com itself, no separate platform or app install."}, {"id": "graycliff_docs_voice_agent_architecture_concierge_widget", "label": "PythaFlow Concierge Widget", "file_type": "concept", "source_file": "Graycliff/docs/Voice_Agent_Architecture.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "~40 KB vanilla-TS widget, one script tag, Shadow-DOM isolated so no CSS bleeds either way; safe on any CMS. async so it can never slow or break the host page; degrades to text chat or a phone number."}, {"id": "graycliff_docs_voice_agent_architecture_voice_gateway", "label": "Voice Gateway", "file_type": "concept", "source_file": "Graycliff/docs/Voice_Agent_Architecture.md", "source_location": "voice-gateway/", "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "New async Python service orchestrating a session; transport adapters (WebSocket v1, WebRTC v1.1, Twilio Media Streams phase 3). Reusable for the phone channel."}, {"id": "graycliff_docs_voice_agent_architecture_turn_state_machine", "label": "Turn State Machine", "file_type": "concept", "source_file": "Graycliff/docs/Voice_Agent_Architecture.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "LISTENING -> THINKING -> SPEAKING per session; barge-in cancels the LLM stream and flushes the TTS queue."}, {"id": "graycliff_docs_voice_agent_architecture_barge_in", "label": "Barge-in", "file_type": "rationale", "source_file": "Graycliff/docs/Voice_Agent_Architecture.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "VAD fires while agent audio plays; gateway cancels LLM + TTS within one frame (~20 ms). The agent stopping when interrupted is ~80% of what makes it feel human."}, {"id": "graycliff_docs_voice_agent_architecture_vad", "label": "On-device VAD (Silero WASM)", "file_type": "concept", "source_file": "Graycliff/docs/Voice_Agent_Architecture.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "End-of-speech + barge-in detection locally, no server round-trip to know the guest is talking."}, {"id": "graycliff_docs_voice_agent_architecture_agent_core", "label": "Agent Core (vendor-blind)", "file_type": "concept", "source_file": "Graycliff/docs/Voice_Agent_Architecture.md", "source_location": "agent.py", "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Extends services/llm.py: prompt assembly (persona + knowledge pack + live context), LLMService interface with streaming + tool-use, tool router."}, {"id": "graycliff_docs_voice_agent_architecture_llmservice_interface", "label": "LLMService Interface (streaming + tool-use)", "file_type": "concept", "source_file": "Graycliff/docs/Voice_Agent_Architecture.md", "source_location": "app/services/llm_service.py", "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "The existing stable seam, extended with streaming and tool-use (generate_stream(prompt, tools, tier))."}, {"id": "graycliff_docs_voice_agent_architecture_provider_wrappers", "label": "STT/LLM/TTS Provider Wrappers", "file_type": "concept", "source_file": "Graycliff/docs/Voice_Agent_Architecture.md", "source_location": "services/providers/", "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "The only swappable layer via .env; the layer that changes when an SDK changes."}, {"id": "graycliff_docs_voice_agent_architecture_stt", "label": "Streaming STT", "file_type": "concept", "source_file": "Graycliff/docs/Voice_Agent_Architecture.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Deepgram > AssemblyAI > Whisper-rt; tuned vocabulary (Graycliff, conch, Junkanoo)."}, {"id": "graycliff_docs_voice_agent_architecture_tts", "label": "Streaming TTS (brand voice)", "file_type": "concept", "source_file": "Graycliff/docs/Voice_Agent_Architecture.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Cartesia > ElevenLabs > Azure; a cloned licensed voice; sentence-chunked, first audio in ~200 ms. A five-star property cannot sound like a GPS."}, {"id": "graycliff_docs_voice_agent_architecture_realtime_s2s", "label": "Realtime Speech-to-Speech (optional)", "file_type": "rationale", "source_file": "Graycliff/docs/Voice_Agent_Architecture.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "e.g. OpenAI Realtime; excellent latency but single-vendor coupling for the whole experience. Supported as one more wrapper behind the same session interface so it can be A/B'd, never depended on."}, {"id": "graycliff_docs_voice_agent_architecture_cascaded_pipeline", "label": "Cascaded Streaming Pipeline (chosen)", "file_type": "rationale", "source_file": "Graycliff/docs/Voice_Agent_Architecture.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Chosen: streaming STT -> LLM -> streaming TTS behind our own gateway. Full control of brand voice/prompt/tools/data; each stage swappable (consistent with LLMService isolation); ~3-6x cheaper per session than managed platforms; gateway reusable for the phone line."}, {"id": "graycliff_docs_voice_agent_architecture_managed_platform", "label": "Managed Voice-Agent Platform (rejected)", "file_type": "rationale", "source_file": "Graycliff/docs/Voice_Agent_Architecture.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Vapi/Retell/Bland rejected: lock-in at the whole-agent level (the exact dependency architected away), per-minute pricing erodes margin, limited brand-voice control, guest audio transits a third party."}, {"id": "graycliff_docs_voice_agent_architecture_tools", "label": "Agent Tools (function calling)", "file_type": "concept", "source_file": "Graycliff/docs/Voice_Agent_Architecture.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "check_availability, create_reservation, answer_menu_question, recommend, start/add/confirm_order, get_property_info, handoff_to_host - each backed by an existing FastAPI endpoint."}, {"id": "graycliff_docs_voice_agent_architecture_actions_api", "label": "Restaurant Actions API", "file_type": "concept", "source_file": "Graycliff/docs/Voice_Agent_Architecture.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "The existing FastAPI platform, hardened: availability/reservations, orders/room-service, menu/pairings/recommender, knowledge pack, handoff. Postgres replaces demo SQLite."}, {"id": "graycliff_docs_voice_agent_architecture_knowledge_pack", "label": "Knowledge Pack", "file_type": "concept", "source_file": "Graycliff/docs/Voice_Agent_Architecture.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Per-restaurant (restaurant_id) table of structured facts + freeform FAQs, editable from the manager dashboard; assembled into the system prompt each session - no fine-tuning, instant updates."}, {"id": "graycliff_docs_voice_agent_architecture_persona", "label": "Concierge Persona", "file_type": "rationale", "source_file": "Graycliff/docs/Voice_Agent_Architecture.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Written once per property; Graycliff's is warm, unhurried, 'our' not 'the', offers the cellar story, never says 'as an AI'."}, {"id": "graycliff_docs_voice_agent_architecture_latency_budget", "label": "Voice-to-Voice Latency Budget", "file_type": "concept", "source_file": "Graycliff/docs/Voice_Agent_Architecture.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "~700-1,100 ms total (target p50 <= 0.9 s): VAD 150-250, STT ~150, LLM first token 250-400 (fast tier), TTS 150-250, network ~100. Region pinned us-east near the Bahamas."}, {"id": "graycliff_docs_voice_agent_architecture_session_token_api", "label": "Session Token API", "file_type": "concept", "source_file": "Graycliff/docs/Voice_Agent_Architecture.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Issues short-lived JWTs; enforces an Origin allowlist (graycliff.com only), per-IP rate limits, session TTLs. The browser script holds no secrets; all provider keys live server-side."}, {"id": "graycliff_docs_voice_agent_architecture_multi_tenant", "label": "Multi-tenant (restaurant_id)", "file_type": "rationale", "source_file": "Graycliff/docs/Voice_Agent_Architecture.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "restaurant_id on every table from day one - the next restaurant is a config row, not a fork."}], "edges": [{"source": "graycliff_docs_voice_agent_architecture_llmservice_interface", "target": "graycliff_readme_llmservice_interface", "relation": "references", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": "Graycliff/docs/Voice_Agent_Architecture.md", "source_location": null, "weight": 1.0}, {"source": "graycliff_docs_voice_agent_architecture_provider_wrappers", "target": "graycliff_readme_provider_wrapper", "relation": "references", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": "Graycliff/docs/Voice_Agent_Architecture.md", "source_location": null, "weight": 1.0}, {"source": "graycliff_docs_voice_agent_architecture_voice_concierge", "target": "graycliff_readme_ai_provider_isolation", "relation": "references", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": "Graycliff/docs/Voice_Agent_Architecture.md", "source_location": null, "weight": 1.0}, {"source": "graycliff_docs_voice_agent_architecture_voice_concierge", "target": "graycliff_readme_voice_ordering", "relation": "references", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": "Graycliff/docs/Voice_Agent_Architecture.md", "source_location": null, "weight": 1.0}, {"source": "graycliff_docs_voice_agent_architecture_agent_core", "target": "graycliff_docs_voice_agent_architecture_llmservice_interface", "relation": "references", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": "Graycliff/docs/Voice_Agent_Architecture.md", "source_location": null, "weight": 1.0}, {"source": "graycliff_docs_voice_agent_architecture_agent_core", "target": "graycliff_docs_voice_agent_architecture_tools", "relation": "calls", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": "Graycliff/docs/Voice_Agent_Architecture.md", "source_location": null, "weight": 1.0}, {"source": "graycliff_docs_voice_agent_architecture_tools", "target": "graycliff_docs_voice_agent_architecture_actions_api", "relation": "calls", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": "Graycliff/docs/Voice_Agent_Architecture.md", "source_location": null, "weight": 1.0}, {"source": "graycliff_docs_voice_agent_architecture_actions_api", "target": "graycliff_readme_recommender", "relation": "references",