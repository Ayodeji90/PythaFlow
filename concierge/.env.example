ENV=dev
APP_VERSION=0.1.0
LOG_LEVEL=INFO

# --- infra ---
# localhost for host runs; docker-compose overrides these for the api container.
DATABASE_URL=postgresql+asyncpg://concierge:concierge@localhost:5432/concierge
REDIS_URL=redis://localhost:6379/0

# --- LLM orchestration (provider-agnostic; swap freely) ---
# provider: nvidia | openai | groq | mistral | openai_compatible
LLM_PROVIDER=nvidia
# Put the key on its own line below — no quotes, no trailing comment.
# NVIDIA keys start with "nvapi-" (get a free one at build.nvidia.com).
LLM_API_KEY=
# Optional base-url override; leave blank to use the provider default.
LLM_BASE_URL=
LLM_MODEL_FAST=meta/llama-3.1-8b-instruct
LLM_MODEL_QUALITY=meta/llama-3.3-70b-instruct
LLM_TEMPERATURE=0.4
LLM_MAX_TOKENS=1024

# --- embeddings (wired in from Day 5) ---
EMBED_PROVIDER=nvidia
EMBED_MODEL=nvidia/nv-embedqa-e5-v5
EMBED_DIM=1024
