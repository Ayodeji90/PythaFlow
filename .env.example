# Copy to .env and fill in real values. Never commit .env.

# --- Lead generation ---
GOOGLE_PLACES_API_KEY=your-google-places-key-here

# --- AI provider (voice concierge + marketing studio) ---
# auto = anthropic if ANTHROPIC_API_KEY is set, else openai if
# OPENAI_API_KEY is set, else none (rule-based fallbacks).
LLM_PROVIDER=auto

# Anthropic (Claude)
ANTHROPIC_API_KEY=your-anthropic-key-here

# Any OpenAI-compatible endpoint (OpenAI, Groq, Mistral, local Ollama...)
#OPENAI_API_KEY=
#OPENAI_BASE_URL=https://api.openai.com/v1

# Optional per-tier model overrides (fast = voice turns, quality = copy)
#LLM_MODEL_FAST=
#LLM_MODEL_QUALITY=
