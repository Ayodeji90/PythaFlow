# Secrets — never commit
.env
.env.*
!.env.example

# Python
.venv/
__pycache__/
*.pyc
*.egg-info/
.pytest_cache/

# Node / frontend
node_modules/
dist/

# Data & artifacts
*.db
*.sqlite3

# Graphify output — generated cache; embeds machine-specific absolute paths and
# local files, so it must not be committed. Regenerate locally with /graphify.
graphify-out/

# OS / editor
.DS_Store
.vscode/
